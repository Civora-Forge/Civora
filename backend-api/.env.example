# Civora Backend Environment Variables
# Copy this file to .env and fill in values as needed.
# Do NOT commit .env to version control.

# Server
PORT=5001
NODE_ENV=development

# Repository mode: "memory" (default) or "firestore"
ISSUE_REPOSITORY=memory

# Google Cloud (only needed when ISSUE_REPOSITORY=firestore)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE_ID=(default)

# AI enrichment toggle (false = stub mode, true = real Gemini calls)
ENABLE_AI_ENRICHMENT=false

# AI enrichment timeout in ms (default: 8000)
# Increase if Gemini responses are timing out but completing shortly after
AI_ENRICHMENT_TIMEOUT_MS=8000

# BigQuery export toggle (false = skipped, true = real export)
ENABLE_BIGQUERY_EXPORT=false

# Dev routes toggle (true = enable POST /dev/seed and DELETE /dev/clear in production)
# Useful for seeding demo data on Render during hackathon
ENABLE_DEV_ROUTES=false

# Gemini API key (only needed when ENABLE_AI_ENRICHMENT=true)
GEMINI_API_KEY=

# Gemini model (default: gemini-2.5-flash)
# Overrides: GEMINI_CLASSIFICATION_MODEL and GEMINI_VISION_MODEL can override per-adapter
GEMINI_MODEL=gemini-2.5-flash

# Firebase Auth (optional, default disabled)
# When enabled, POST /issues attaches userId if valid Firebase token is provided
# GET /issues/my requires a valid Firebase token
ENABLE_FIREBASE_AUTH=false
FIREBASE_PROJECT_ID=
